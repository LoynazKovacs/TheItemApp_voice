{
  "version": 2,
  "appKey": "voice",
  "appVersion": "1.1.0",
  "engineRequires": ">=1.0.0",
  "requiresCore": true,
  "collections": [
    {
      "collection": "apps",
      "file": "apps.json",
      "matchBy": "key",
      "installMode": "shared",
      "exportFields": ["key", "name", "description", "icon", "enabled", "groupIds", "cantDelete"],
      "filter": { "key": "voice" }
    },
    {
      "collection": "items",
      "file": "items.json",
      "matchBy": "key",
      "installMode": "shared",
      "exportFields": [
        "key",
        "collection",
        "title",
        "titleSingular",
        "titlePlural",
        "description",
        "ai",
        "icon",
        "appId",
        "behavior",
        "schema",
        "ui",
        "api",
        "auth",
        "tier",
        "kind",
        "meta"
      ],
      "filter": { "appId": "<thisAppId>" }
    },
    {
      "collection": "prefabs",
      "file": "prefabs.json",
      "matchBy": "_id",
      "installMode": "shared",
      "exportFields": [
        "key",
        "title",
        "description",
        "icon",
        "type",
        "displayType",
        "reserved",
        "frontend",
        "defaultTile"
      ]
    },
    {
      "collection": "dashboards",
      "file": "dashboards.json",
      "matchBy": "_id",
      "installMode": "installConfig",
      "exportFields": [
        "appId",
        "name",
        "icon",
        "isHome",
        "statusId",
        "interactive",
        "groupIds",
        "gridsterConfigId",
        "tiles"
      ],
      "filter": { "appId": "<thisAppId>" }
    },
    {
      "collection": "windows",
      "file": "windows.json",
      "matchBy": "_id",
      "installMode": "installConfig",
      "exportFields": [
        "dashboardId",
        "title",
        "icon",
        "groupIds",
        "modelId",
        "prefabId",
        "prefabConfig",
        "sort"
      ]
    },
    {
      "collection": "voice_notes",
      "file": "data/voice_notes.json",
      "matchBy": "_id",
      "installMode": "manualOrSystem",
      "exportFields": [
        "title",
        "audioFileId",
        "transcript",
        "language",
        "durationMs",
        "mimeType",
        "groupIds"
      ]
    },
    {
      "collection": "voice_voices",
      "file": "data/voice_voices.json",
      "matchBy": "key",
      "installMode": "shared",
      "exportFields": [
        "key",
        "displayName",
        "description",
        "engine",
        "profileId",
        "audioFileId",
        "refText",
        "language",
        "gender",
        "style",
        "enabled",
        "order",
        "groupIds"
      ]
    },
    {
      "collection": "users",
      "file": "users.json",
      "matchBy": "_id",
      "installMode": "shared",
      "exportFields": ["username", "usernameLower", "isSystem", "groupIds", "isFunctional", "appId"]
    },
    {
      "collection": "actions",
      "file": "actions.json",
      "matchBy": "key",
      "installMode": "shared",
      "exportFields": [
        "key",
        "modelId",
        "type",
        "kind",
        "label",
        "tooltip",
        "description",
        "icon",
        "iconKey",
        "order",
        "color",
        "config",
        "inputSchema",
        "visibleWhen",
        "disabledWhen",
        "ui",
        "groupIds"
      ],
      "filter": { "appId": "<thisAppId>" }
    },
    {
      "collection": "scenarios",
      "file": "scenarios.json",
      "matchBy": "key",
      "installMode": "shared",
      "exportFields": [
        "key",
        "title",
        "subtitle",
        "description",
        "appKey",
        "mode",
        "trigger",
        "audience",
        "isPublished",
        "version",
        "tags",
        "steps"
      ],
      "filter": { "appKey": "voice" }
    }
  ],
  "routes": [
    {
      "type": "federation-remote",
      "pathPrefix": "/mf/voice",
      "upstream": "voice:80"
    },
    {
      "type": "api-proxy",
      "pathPrefix": "/voice-api",
      "upstream": "voice-api:3005",
      "readTimeout": "5m"
    }
  ]
}
