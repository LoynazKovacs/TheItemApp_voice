    },
    "key": "dani-es-c9b83c",
    "displayName": "dani_es",
    "engine": "omnivoice",
    "profileId": "b47156ca",
    "audioFileId": {
      "$oid": "6a0f936fabf9923632c9b83a"
    },
    "refText": "Bienvenidos a Madrid. Ahora les vamos a enseñar cómo esta aplicación funciona y cuáles son las mejores propiedades que tiene.  Disfrutad con este camino que os va a enseñar a hacer todo tipo de cosas.",
    "language": "es",
    "style": [],
