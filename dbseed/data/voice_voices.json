    "engine": "omnivoice",
    "profileId": "0f48ba94",
    "audioFileId": {
      "$oid": "6a0f9367abf9923632c9b7d2"
    },
    "refText": "Sziasztok! Ez az applikáció, ez nagyon jó!  Gyertek, tanuljátok meg, hogy hogyan működik, és akkor ki fogjátok tudni használni az összes!",
    "language": "hu",
