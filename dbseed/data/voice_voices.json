    },
    "key": "dani-hu",
    "displayName": "Dani (HU)",
    "engine": "omnivoice",
    "profileId": "29f793f7",
    "audioFileId": {
      "$oid": "6a0f8979abf9923632c8fe60"
    },
    "refText": "Most ezzel csináljunk egy új hangot, amivel bemutatjuk Dániel csodálatos hangját. Ez egy kicsit hosszabb lesz, mint a többi, de megéri, mert sokkal több információ lesz minden egyes szóban.",
    "language": "hu",
    "style": [],
    "enabled": true,
    "groupIds": [
      {
        "$oid": "7000000000000000001d0002"
      }
    ]
  },
  {
